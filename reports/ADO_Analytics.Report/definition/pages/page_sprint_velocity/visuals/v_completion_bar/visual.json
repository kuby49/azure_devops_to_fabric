{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.3.0/schema.json",
  "name": "v_completion_bar",
  "position": {
    "x": 640,
    "y": 140,
    "z": 5,
    "height": 260,
    "width": 600,
    "tabOrder": 5
  },
  "visual": {
    "visualType": "clusteredBarChart",
    "query": {
      "queryState": {
        "Values": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "fact_sprint_metrics"
                    }
                  },
                  "Property": "iteration_name"
                }
              },
              "queryRef": "fact_sprint_metrics.iteration_name",
              "nativeQueryRef": "iteration_name"
            },
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "fact_sprint_metrics"
                    }
                  },
                  "Property": "Completion Rate %"
                }
              },
              "queryRef": "fact_sprint_metrics.Completion Rate %",
              "nativeQueryRef": "Completion Rate %"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}